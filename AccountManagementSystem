            });

            accounts.Add(new Account
            {
                AccountId = Guid.NewGuid(),
                Username = "user",
                Password = "user123"
            });

            accounts.Add(new Account
            {
                AccountId = Guid.NewGuid(),
                Username = "guest",
                Password = "guest123"
            });
        }

        public List<Account> GetAccounts()
        {
            return accounts;
        }
    }
}
